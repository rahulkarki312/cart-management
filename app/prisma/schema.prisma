generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model inventory_category {
  id                       Int                  @id @default(autoincrement())
  parent_id                Int?
  name                     String               @unique @db.VarChar(50)
  slug                     String               @unique @db.VarChar(55)
  is_active                Boolean              @default(false)
  level                    Int                  @default(0) @db.SmallInt
  inventory_category       inventory_category?  @relation("inventory_categoryToinventory_category", fields: [parent_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  other_inventory_category inventory_category[] @relation("inventory_categoryToinventory_category")
  inventory_product        inventory_product[]
}

model inventory_product {
  id                 Int                 @id @default(autoincrement())
  category_id        Int?
  name               String              @unique @db.VarChar(50)
  slug               String              @unique @db.VarChar(55)
  description        String?
  is_digital         Boolean             @default(false)
  is_active          Boolean             @default(false)
  created_at         DateTime            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?           @db.Timestamp(6)
  price              Decimal             @db.Decimal(10, 2)
  inventory_category inventory_category? @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
